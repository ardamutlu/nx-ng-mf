{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@spartan-ng/helm/select": ["libs/ui/select/src/index.ts"],
      "@spartan-ng/helm/utils": ["libs/ui/utils/src/index.ts"],
      "@spartan-ng/helm/icon": ["libs/ui/icon/src/index.ts"],
      "@spartan-ng/helm/button": ["libs/ui/button/src/index.ts"],
      "@spartan-ng/helm/dropdown-menu": ["libs/ui/dropdown-menu/src/index.ts"],
      "@spartan-ng/helm/separator": ["libs/ui/separator/src/index.ts"],
      "@spartan-ng/helm/sidebar": ["libs/ui/sidebar/src/index.ts"],
      "@spartan-ng/helm/input": ["libs/ui/input/src/index.ts"],
      "@spartan-ng/helm/sheet": ["libs/ui/sheet/src/index.ts"],
      "@spartan-ng/helm/skeleton": ["libs/ui/skeleton/src/index.ts"],
      "@spartan-ng/helm/tooltip": ["libs/ui/tooltip/src/index.ts"],
      "@spartan-ng/helm/breadcrumb": ["libs/ui/breadcrumb/src/index.ts"],
      "@spartan-ng/helm/collapsible": ["libs/ui/collapsible/src/index.ts"],
      "@spartan-ng/helm/avatar": ["libs/ui/avatar/src/index.ts"],
      "@spartan-ng/helm/card": ["libs/ui/card/src/index.ts"],
      "@spartan-ng/helm/field": ["libs/ui/field/src/index.ts"],
      "@spartan-ng/helm/label": ["libs/ui/label/src/index.ts"],
      "auth/Routes": ["apps/auth/src/app/app.routes.ts"],
      "dashboard/Routes": ["apps/dashboard/src/app/app.routes.ts"],
      "@company/auth/data-access": ["libs/auth/data-access/src/index.ts"],
      "@company/auth/feature-login": ["libs/auth/feature-login/src/index.ts"],
      "@company/i18n": ["libs/i18n/src/index.ts"],
      "@company/core": ["libs/core/src/index.ts"],
      "@company/shared/ui": ["libs/shared/ui/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
